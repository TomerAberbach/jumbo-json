{
  "name": "jumbo-json",
  "version": "0.1.1",
  "description": "For when you have a Boeing 747 worth of JSON you want in memory",
  "keywords": [
    "json",
    "parser",
    "streaming",
    "large"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikecluck/jumbo-json.git"
  },
  "author": "Mike Cluck",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "node --test 'test/**/*.test.ts'",
    "test:watch": "node --test --watch 'test/**/*.test.ts'",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "beta",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.7.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1"
  },
  "packageManager": "pnpm@10.27.0"
}
